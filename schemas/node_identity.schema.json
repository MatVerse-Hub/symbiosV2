{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matverse.local/schemas/node_identity.schema.json",
  "title": "NodeIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_id", "node_type", "public_key_ref"],
  "properties": {
    "node_id": {"type": "string", "minLength": 1},
    "node_type": {"enum": ["APP", "AGENT", "API", "DEVICE", "CHAIN", "LLM", "GATEWAY", "VALIDATOR", "OTHER"]},
    "public_key_ref": {"type": "string", "minLength": 1},
    "trust_level": {"enum": ["INTERNAL", "LOCAL", "EXTERNAL", "PUBLIC", "ADVERSARIAL"]},
    "metadata": {"type": "object"}
  }
}
